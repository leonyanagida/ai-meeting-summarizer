# Hugging Face API Key
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Redis Configuration (Upstash)
# Option 1 (Recommended): Add directly through Vercel
# 1. Go to your Vercel project
# 2. Click "Storage"
# 3. Select "Connect Store" -> "Upstash Redis"
# 4. Follow the prompts to create/connect your database
# Vercel will automatically add these environment variables:
STORAGE_KV_REST_API_URL=your_upstash_redis_rest_url_here
STORAGE_KV_REST_API_TOKEN=your_upstash_redis_rest_token_here

# Optional: Model ID (if you want to use a different model)
# Default: philschmid/bart-large-cnn-samsum
# HUGGINGFACE_MODEL_ID=your_preferred_model_id